# Backend
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
CHROMA_PERSIST_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_docs
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_CHUNKS=5
MAX_PDF_SIZE_MB=50
DEBUG=true

# LLM backend switch
# Use "ollama" before training, switch to "huggingface" after training
LLM_BACKEND=ollama
HF_MODEL_PATH=./data/fine_tuned_model

# Frontend (.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
