OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
CHROMA_PERSIST_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_docs
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_CHUNKS=5
MAX_PDF_SIZE_MB=50
UPLOAD_DIR=./data/uploads
DEBUG=true

# LLM backend: "ollama" (default) or "huggingface" (after training)
LLM_BACKEND=ollama
# Set this after training completes:
# LLM_BACKEND=huggingface
# HF_MODEL_PATH=./data/fine_tuned_model
